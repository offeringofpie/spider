---
import Layout from '../layouts/Layout.astro';
import Home from '../layouts/Home';
import Progress from '../components/Progress';
import Header from '../components/Header';
import Sprite from '../components/Sprite';

// ✅ This tells Astro to build this as a static HTML file at deploy time
export const prerender = true;

// Default generic metadata for the App Shell
const title = 'Spider Parser';
const description = 'Parse news articles and web pages with ease.';
const url = Astro.url.href;
const image = 'https://spider.jlopes.eu/spiderweb.jpg';
const type = 'website';
---

<Layout {title} {description} {url} {image} {type}>
  <Progress client:load />
  <Header client:only />
  <main class="mx-auto max-w-4xl px-6 py-10">
    <Home client:only />
    <Sprite />
  </main>
</Layout>

<script>
  if (import.meta.env.DEV) {
    // @ts-expect-error
    window.$RefreshReg$ = () => {};
    // @ts-expect-error
    window.$RefreshSig$ = () => () => {};
  }

  if (window.self !== window.top) {
    document.documentElement.dataset.embedded = 'true';
  }
</script>
