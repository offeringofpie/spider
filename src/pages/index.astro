---
import Layout from '../layouts/Layout.astro';
import Home from '../layouts/Home';
import Progress from '../components/Progress';
import Header from '../components/Header';
import Sprite from '../components/Sprite';
import Fab from '../components/Fab';
import Translate from '../components/Translate';
import Settings from '../components/Settings';

const q = Astro.url.searchParams.get('q');
const userAgent = Astro.request.headers.get('user-agent') || '';

const isBot =
  /bot|facebook|twitter|slack|discord|whatsapp|telegram|linkedin|skype/i.test(
    userAgent,
  );

let title = 'Spider Parser';
let description = 'Parse news articles and web pages with ease.';
let url = Astro.url.href;
let image = 'https://spider.jlopes.eu/spiderweb.jpg';
let type = 'website';

if (q && isBot) {
  type = 'article';
  try {
    const apiUrl = `${Astro.url.origin}/api/parse?q=${encodeURIComponent(q)}`;
    const res = await fetch(apiUrl);

    if (res.ok) {
      const article = await res.json();

      title = article.title || article.meta_title || `Parsed: ${q}`;

      const articleDescription =
        article.dek || article.excerpt || article.description || '';
      description = articleDescription
        ? articleDescription.slice(0, 200)
        : `Clean reader view of ${q}`;

      image = article.lead_image_url || article.image || image;
    }
  } catch (err) {
    console.error('Failed to fetch OG data:', err);
    title = `Spider Parser – ${q}`;
    description = `Clean reader view of ${q}`;
  }
}
---

<Layout {title} {description} {url} {image} {type}>
  <Progress client:load />
  <Header client:only />
  <Translate client:only />
  <Settings client:only />

  <main class="mx-auto max-w-4xl px-6 py-10">
    <Home client:only />
    <Fab client:only />
    <Sprite />
  </main>
</Layout>

<script is:inline>
  if (typeof window !== 'undefined') {
    window.$RefreshReg$ = window.$RefreshReg$ || function () {};
    window.$RefreshSig$ =
      window.$RefreshSig$ ||
      function () {
        return function () {};
      };
  }
</script>

<script>
  if (window.self !== window.top) {
    document.documentElement.dataset.embedded = 'true';
  }
</script>
