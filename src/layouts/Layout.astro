---
import { defaultStore } from '../store/store';
import '../styles/global.css';

const state = defaultStore.getState();
let currentTheme = state.theme;
let currentFont = state.font;

const {
  title = 'Spider Parser',
  description = 'Parse news articles and web pages with ease.',
  url = 'https://spider.jlopes.eu/',
  image = 'https://spider.jlopes.eu/spiderweb.jpg',
  type = 'article',
} = Astro.props;

defaultStore.subscribe(() => {
  const currentState = defaultStore.getState();
  const theme = currentState.theme;
  const font = currentState.font;
  currentTheme = theme;
  currentFont = font;
});
---

<!doctype html>
<html lang="en" data-theme={currentTheme} data-font={currentFont}>
  <head>
    <title>{title}</title>
    <link rel="canonical" href={new URL(Astro.url.pathname, url).toString()} />
    <link rel="alternate" href="/llms.txt" title="LLMs.txt" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta http-equiv="content-type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <meta name="description" content={description} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:creator" content="jelo" />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    {/* Open Graph */}
    <meta name="og:type" content={type} />
    <meta name="og:url" content={url} />
    <meta name="og:image" content={image} />
    <meta name="og:image:width" content="1200" />
    <meta name="og:image:height" content="630" />
    <meta name="og:site_name" content="Spider Parser" />
    <meta name="og:title" content={title} />
    <meta name="og:description" content={description} />
    <meta
      name="robots"
      content="max-snippet:-1, max-image-preview:large, max-video-preview:-1"
    />
    <script
      id="app-jsonld"
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@graph': [
          {
            '@type': 'WebSite',
            '@id': 'https://spider.jlopes.eu/#website',
            url: 'https://spider.jlopes.eu/',
            name: 'Spider Parser',
            description: 'Parse news articles and web pages with ease.',
          },
          {
            '@type': 'WebApplication',
            '@id': 'https://spider.jlopes.eu/#app',
            name: 'Spider Parser',
            url: 'https://spider.jlopes.eu/',
            description: 'A clean reader view for news articles and web pages.',
            applicationCategory: 'UtilityApplication',
            browserRequirements:
              'Requires a modern web browser with JavaScript enabled.',
            isPartOf: { '@id': 'https://spider.jlopes.eu/#website' },
          },
        ],
      })}
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin="anonymous"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Almendra:ital,wght@0,400;0,700;1,400&family=Comic+Neue:ital,wght@0,400;0,700;1,400&family=Courier+Prime:ital,wght@0,400;0,700;1,400&family=Pinyon+Script&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <script>
      import { defaultStore } from '../store/store';

      defaultStore.setState({
        posts: false,
        loading: false,
        loaded: false,
        initialized: true,
        showTranslateBar: false,
      });

      function updateTheme() {
        const state = defaultStore.getState();
        const theme = state.theme;
        const font = state.font;
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.setAttribute('data-font', font);
      }

      updateTheme();
      defaultStore.subscribe(updateTheme);
    </script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
